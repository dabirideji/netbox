# Netbox development defaults.
# Keep real secrets in .env.local; this file should stay safe to share.

NETBOX_ENV=development
NETBOX_CONFIG_DIR=config

NETBOX_HOST=127.0.0.1
NETBOX_PORT=4177
NETBOX_FRONTEND_HOST=127.0.0.1
NETBOX_FRONTEND_PORT=5177
NETBOX_PREVIEW_PORT=4178

NETBOX_DB_PATH=data/netbox.sqlite3
NETBOX_WIFI_NAME=
NETBOX_TARGETS=

VITE_NETBOX_APP_NAME=Netbox

# Optional Pexels wallpaper proxy (https://www.pexels.com/api/).
# Set the real key in .env.local; leave blank here to disable wallpapers.
PEXELS_API_KEY=
